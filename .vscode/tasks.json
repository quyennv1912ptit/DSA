{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build and Run with Input/Output",
      "type": "shell",
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "windows": {
        "command": "pwsh",
        "args": [
          "-Command",
          "g++ \"${file}\" -o \"${fileBasenameNoExtension}.exe\" && Get-Content input.txt | .\\\"${fileBasenameNoExtension}.exe\" | Out-File output.txt && Remove-Item \"${fileBasenameNoExtension}.exe\""
        ]
      },
      "linux": {
        "command": "bash",
        "args": [
          "-c",
          "g++ \"${file}\" -o \"${fileBasenameNoExtension}\" && ./\"${fileBasenameNoExtension}\" < input.txt > output.txt && rm \"${fileBasenameNoExtension}\""
        ]
      },
      "osx": {
        "command": "bash",
        "args": [
          "-c",
          "g++ \"${file}\" -o \"${fileBasenameNoExtension}\" && ./\"${fileBasenameNoExtension}\" < input.txt > output.txt && rm \"${fileBasenameNoExtension}\""
        ]
      }
    }
  ]
}