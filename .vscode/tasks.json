{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build and Run with Input/Output",
      "type": "shell",
      "problemMatcher": ["$gcc"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "windows": {
        "command": "g++ \"${file}\" -o \"${fileBasenameNoExtension}.exe\" && Get-Content input.txt | & \".\\${fileBasenameNoExtension}.exe\" | Out-File output.txt && Remove-Item \"${fileBasenameNoExtension}.exe\""
      },
      "linux": {
        "command": "g++ \"${file}\" -o \"${fileBasenameNoExtension}\" && ./\"${fileBasenameNoExtension}\" < input.txt > output.txt && rm \"${fileBasenameNoExtension}\""
      },
      "osx": {
        "command": "g++ \"${file}\" -o \"${fileBasenameNoExtension}\" && ./\"${fileBasenameNoExtension}\" < input.txt > output.txt && rm \"${fileBasenameNoExtension}\""
      }
    }
  ]
}